# ===========================================
# GhostPay Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# Never commit .env files to version control
# ===========================================

# ===========================================
# Application
# ===========================================
NODE_ENV=development
APP_NAME=GhostPay
APP_VERSION=0.1.0
APP_URL=http://localhost:3000

# ===========================================
# Backend API
# ===========================================
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000
API_PREFIX=/api/v1

# ===========================================
# Frontend
# ===========================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://ghostpay:password@localhost:5432/ghostpay?schema=public

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# Stellar Blockchain
# ===========================================
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# For mainnet (production):
# STELLAR_NETWORK=public
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# ===========================================
# Redis (for caching and sessions)
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# Email/Notifications (optional)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@guestpay.io

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Consolidation Job (Cron)
# ===========================================
CONSOLIDATION_CRON=0 */6 * * *
CONSOLIDATION_ENABLED=true

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ===========================================
# CORS
# ===========================================
CORS_ORIGIN=http://localhost:3000

# ===========================================
# Security
# ===========================================
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=your-32-character-encryption-key-here-change-in-production

# ===========================================
# Docker
# ===========================================
DOCKER_DB_HOST=postgres
DOCKER_REDIS_HOST=redis